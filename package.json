    "@11ty/eleventy": "3.1.5",
    "@11ty/eleventy-plugin-rss": "3.0.0",
    "concurrently": "9.2.1",
    "postcss": "8.5.8",
    "autoprefixer": "10.4.27",
    "html-minifier-terser": "7.2.0",
    "htmlencode": "0.0.4",
    "markdown-it": "14.1.1",
    "markdown-it-anchor": "9.2.0",
    "shiki": "4.0.2",
    "@shikijs/transformers": "4.0.2",
    "terser": "5.46.1",
    "@tailwindcss/typography": "0.5.19",
    "tailwindcss": "3.4.19"
  },
