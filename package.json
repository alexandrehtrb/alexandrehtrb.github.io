      "liquidjs@<10.25.2": "10.25.2",
      "markdown-it@<14.1.1": "14.1.1",
      "mdast-util-to-hast@<13.2.1": "13.2.1",
      "minimatch@<10.2.4": "10.2.4",
      "picomatch@<4.0.4": "4.0.4",
